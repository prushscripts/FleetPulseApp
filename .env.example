# Copy this file to .env in THIS folder (FleetPulseApp), not the Next.js repo root.
# Use EXPO_PUBLIC_* here — do not use NEXT_PUBLIC_* (that is only for the web app).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Your deployed Next.js FleetPulse URL (no trailing slash) — required for:
# - driver "Report issue" (Bearer auth to /api/driver-report-issue)
# - failed inspection notifications (/api/notifications/create)
EXPO_PUBLIC_WEB_URL=https://your-fleetpulse-deployment.vercel.app
